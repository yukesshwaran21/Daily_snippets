import java.util.*;

class Main {
    public static void main(String[] args) {

        int[] arr1 = {2, 3, -2, 4};

        int max=arr1[0];

        for (int i = 0; i < arr1.length; i++) {
                int  value = 1;
            for (int j = i; j < arr1.length; j++) {

                 value *= arr1[j];
                
                max=Math.max(max,value);
            }
        }

        System.out.println(max);
    }
}
