class Solution {
    public int maximumWealth(int[][] accounts) {
        
        int max=Integer.MIN_VALUE;
            for(int j=0;j<accounts.length;j++){
                int sum=0;
                for(int k=0;k<accounts[j].length;k++){
                    sum += accounts[j][k];
                }
                 max=Math.max(max,sum);
            }
           
        
        return max;
    }
}
