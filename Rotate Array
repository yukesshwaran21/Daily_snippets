class Solution {
    public void rotate(int[] nums, int k) {
        
        ArrayList<Integer> l=new ArrayList<>();
        k=k%nums.length;

        for(int j=nums.length-k;j<nums.length;j++){
             l.add(nums[j]);
          }
        for(int m=0;m<nums.length-k;m++){
            l.add(nums[m]);
        }


        for(int i=0;i<nums.length;i++){
            nums[i]=l.get(i);
        }
    }
}
