class Solution {
    public boolean isValid(String s) {
        
        Stack<Character> l=new Stack<>();

        for(char c: s.toCharArray()){
            if(c=='(' || c=='{' || c=='['){
                l.push(c);
            }
            else{
                if(l.isEmpty()){
                    return false;
                }
                char t=l.pop();
                if(c==')' && t!='(' || c=='}' && t!='{' || c==']' && t!='['){
                    return false;
                }
            }
        }
        return l.isEmpty();
    }
}
