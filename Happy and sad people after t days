import java.util.*;

class Main {
    public static void main(String[] args) {
        Scanner sc=new Scanner(System.in);
        
        int n=sc.nextInt();
        
        int t=sc.nextInt();
        
        int happy=n;
        int sad=0;
        
        for(int i=0;i<t;i++){
          double tsad= happy*0.7 + sad*0.5;
          double thappy= happy*0.3 + sad*0.5;
          happy= (int) thappy;
          sad= (int) tsad;
        }
        System.out.print(happy+" "+sad);
    }
}
